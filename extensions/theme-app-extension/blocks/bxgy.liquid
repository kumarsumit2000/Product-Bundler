{% comment %} Bundler — Buy X, get Y widget. {% endcomment %}
<div
  class="pumper-mount"
  data-pumper-type="bxgy"
  data-product-id="{{ product.id }}"
  data-product-handle="{{ product.handle }}"
  data-shop="{{ shop.permanent_domain }}"
  style="min-height:180px"
></div>

{% schema %}
{
  "name": "Bundler — Buy X, Get Y",
  "target": "section",
  "enabled_on": { "templates": ["product"] },
  "settings": []
}
{% endschema %}
