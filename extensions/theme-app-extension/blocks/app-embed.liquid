{% comment %} Bundler — App Embed. Loads the widget once per page. {% endcomment %}
<script>
  window._pumperConfig = {
    shop: "{{ shop.permanent_domain }}",
    locale: "{{ request.locale.iso_code }}",
    currency: "{{ cart.currency.iso_code }}",
    apiBase: "https://bundler.deepseatools.in/api/storefront",
    {% if customer %}
    customerId: "{{ customer.id }}",
    {% endif %}
    {% if template contains 'product' and product %}
    productId: "gid://shopify/Product/{{ product.id }}",
    productTitle: {{ product.title | json }},
    productImage: {{ product.featured_image | image_url: width: 200 | json }},
    productCollectionIds: [{% for c in product.collections %}"gid://shopify/Collection/{{ c.id }}"{% unless forloop.last %},{% endunless %}{% endfor %}],
    productVariants: [
      {% for v in product.variants %}
      {
        variantId: "gid://shopify/ProductVariant/{{ v.id }}",
        title: {{ v.title | json }},
        priceCents: {{ v.price }},
        available: {{ v.available | json }},
        sellingPlanAllocations: [
          {% for a in v.selling_plan_allocations %}{ planId: "gid://shopify/SellingPlan/{{ a.selling_plan.id }}", priceCents: {{ a.per_delivery_price | default: a.price }} }{% unless forloop.last %},{% endunless %}{% endfor %}
        ]
      }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ],
    requiresSellingPlan: {{ product.requires_selling_plan | json }},
    sellingPlanGroups: [
      {% for g in product.selling_plan_groups %}
      { id: {{ g.id | json }}, name: {{ g.name | json }}, plans: [
        {% for p in g.selling_plans %}{ id: "gid://shopify/SellingPlan/{{ p.id }}", name: {{ p.name | json }} }{% unless forloop.last %},{% endunless %}{% endfor %}
      ] }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ],
    {% comment %}
      Products from the current product's primary (first non-frontpage) collection.
      Powers mix-and-match bundles configured to follow the current product's
      collection. Capped at 12 to keep markup weight reasonable.
    {% endcomment %}
    {% assign current_collection = nil %}
    {% for c in product.collections %}
      {% unless c.handle == 'frontpage' or c.handle == 'all' %}
        {% assign current_collection = c %}
        {% break %}
      {% endunless %}
    {% endfor %}
    {% if current_collection %}
    currentCollectionId: "gid://shopify/Collection/{{ current_collection.id }}",
    currentCollectionProducts: [
      {% for p in current_collection.products limit: 12 %}
      {
        productId: "gid://shopify/Product/{{ p.id }}",
        variantId: "gid://shopify/ProductVariant/{{ p.selected_or_first_available_variant.id }}",
        title: {{ p.title | json }},
        image: {{ p.featured_image | image_url: width: 200 | json }},
        available: {{ p.available | json }},
        priceCents: {{ p.price }}
      }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ]
    {% endif %}
    {% endif %}
  };
</script>
<script src="{{ 'widget.js' | asset_url }}" defer></script>
<link rel="stylesheet" href="{{ 'widget.css' | asset_url }}">

{% schema %}
{
  "name": "Bundler",
  "target": "head"
}
{% endschema %}
